[Unit]
Description=Manteclaw Litcoiin Standalone Miner
After=network.target

[Service]
Type=simple
WorkingDirectory=/root/.openclaw/workspace/projects/litcoin
Environment="LITCOIN_SEED_FILE=/root/.openclaw/workspace/.keys/wallet.seed"
Environment="FIREWORKS_API_KEY=fw_26tRWzW5noUbJBbF9PGd6y"
Environment="PYTHONUNBUFFERED=1"
Environment="NVIDIA_API_KEY=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"
ExecStart=/root/.openclaw/workspace/projects/litcoin/venv/bin/python3 /root/.openclaw/workspace/projects/litcoin/standalone-miner.py 0 3
Restart=always
RestartSec=10
StandardOutput=append:/root/.openclaw/workspace/projects/litcoin/miner_service.log
StandardError=append:/root/.openclaw/workspace/projects/litcoin/miner_service.log

[Install]
WantedBy=default.target
